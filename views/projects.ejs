<%- include("partials/header") %>

    <section class="page-intro">
        <h1><%= title %></h1>
        <p>
            Browse current service projects and discover ways to get involved in your
            community.
        </p>
    </section>

    <section class="list-section">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <article class="list-item">
                    <h2>
                        <%= new Date(project.project_date).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric"
                        }) %>:
                        <%= project.project_title %> (<%= project.organization_name %>)
                    </h2>
                    <p><%= project.project_description %></p>
                    <p><strong>Location:</strong> <%= project.project_location %></p>
                </article>
            <% }) %>
        <% } else { %>
            <article class="list-item">
                <h2>No projects found</h2>
                <p>Please check your database connection and project data.</p>
            </article>
        <% } %>
    </section>

<%- include("partials/footer") %>
