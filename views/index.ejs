<%- include("partials/header") %>

    <section class="hero">
        <h1>
            <%= title %>
        </h1>
        <p>
            Welcome to our community service website. Explore organizations, service
            projects, and categories that help make a positive difference.
        </p>
        <a class="button" href="/projects">View Projects</a>
    </section>

    <section class="card-grid">
        <article class="card">
            <h2>Organizations</h2>
            <p>Learn about local organizations that support meaningful service opportunities.</p>
            <a href="/organizations">Explore Organizations</a>
        </article>

        <article class="card">
            <h2>Projects</h2>
            <p>Find service projects that match your interests and availability.</p>
            <a href="/projects">Explore Projects</a>
        </article>

        <article class="card">
            <h2>Categories</h2>
            <p>Browse project categories such as environmental, educational, and wellness.</p>
            <a href="/categories">Explore Categories</a>
        </article>
    </section>

    <%- include("partials/footer") %>
