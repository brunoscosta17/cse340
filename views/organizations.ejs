<%- include("partials/header") %>

    <section class="page-intro">
        <h1><%= title %></h1>
        <p>
            Learn about local organizations that sponsor service opportunities in the
            community.
        </p>
    </section>

    <section class="card-grid">
        <% if (organizations && organizations.length > 0) { %>
            <% organizations.forEach(organization => { %>
                <article class="card">
                    <h2><%= organization.organization_name %></h2>
                    <p><%= organization.organization_description %></p>

                    <% if (organization.organization_image) { %>
                        <img
                            src="/images/<%= organization.organization_image %>"
                            alt="<%= organization.organization_name %>"
                        >
                    <% } %>
                </article>
            <% }) %>
        <% } else { %>
            <article class="card">
                <h2>No organizations found</h2>
                <p>Please check your database connection and organization data.</p>
            </article>
        <% } %>
    </section>

<%- include("partials/footer") %>
