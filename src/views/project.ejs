<%- include("partials/header") %>

    <section class="page-intro">
        <h1>
            <%= project.project_title %>
        </h1>
        <p>
            View the details for this service project and explore related categories.
        </p>
    </section>

    <section class="list-section">
        <article class="list-item">
            <p>
                <%= project.project_description %>
            </p>

            <p>
                <strong>Date:</strong>
                <%= new Date(project.project_date).toLocaleDateString("en-US", { year: "numeric" , month: "long" ,
                    day: "numeric" }) %>
            </p>

            <p><strong>Location:</strong>
                <%= project.project_location %>
            </p>

            <p>
                <strong>Organization:</strong>
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
            </p>

            <div class="category-tags">
                <strong>Categories:</strong>
                <% if (categories && categories.length> 0) { %>
                    <div class="tag-list">
                        <% categories.forEach(category=> { %>
                            <a class="tag" href="/category/<%= category.category_id %>">
                                <%= category.category_name %>
                            </a>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <p>No categories assigned to this project.</p>
                        <% } %>
            </div>
        </article>
    </section>

    <%- include("partials/footer") %>
