<%- include("partials/header") %>

    <section class="page-intro">
        <h1>
            <%= formTitle %>
        </h1>
        <p>Use the form below to <%= formTitle.toLowerCase() %>.</p>
    </section>

    <% if (success_messages && success_messages.length> 0) { %>
        <section class="flash-message success">
            <% success_messages.forEach(message=> { %>
                <p>
                    <%= message %>
                </p>
                <% }) %>
        </section>
        <% } %>

            <% if (error_messages && error_messages.length> 0) { %>
                <section class="flash-message error">
                    <% error_messages.forEach(message=> { %>
                        <p>
                            <%= message %>
                        </p>
                        <% }) %>
                </section>
                <% } %>

                    <% if (errors && errors.length> 0) { %>
                        <section class="flash-message error">
                            <ul>
                                <% errors.forEach(error=> { %>
                                    <li>
                                        <%= error.msg %>
                                    </li>
                                    <% }) %>
                            </ul>
                        </section>
                        <% } %>

                            <section class="form-section">
                                <form action="<%= action %>" method="post" class="data-form">
                                    <div class="form-group">
                                        <label for="category_name">Category Name</label>
                                        <input type="text" id="category_name" name="category_name"
                                            value="<%= category.category_name || "" %>" required maxlength="100">
                                        <small>Required. Maximum 100 characters.</small>
                                    </div>

                                    <button type="submit">Save Category</button>
                                </form>
                            </section>

                            <%- include("partials/footer") %>
