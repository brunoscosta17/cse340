<%- include("partials/header") %>

    <section class="page-intro">
        <h1>
            <%= title %>
        </h1>
        <p>
            Explore our partner organizations and learn more about the service opportunities they provide.
        </p>
    </section>

    <section class="card-grid">
        <% if (organizations && organizations.length> 0) { %>
            <% organizations.forEach(organization=> { %>
                <article class="card">
                    <% if (organization.organization_image) { %>
                        <img src="/images/<%= organization.organization_image %>"
                            alt="<%= organization.organization_name %>">
                        <% } %>

                            <h2>
                                <a href="/organization/<%= organization.organization_id %>">
                                    <%= organization.organization_name %>
                                </a>
                            </h2>

                            <p>
                                <%= organization.organization_description %>
                            </p>
                </article>
                <% }) %>
                    <% } else { %>
                        <article class="card">
                            <h2>No organizations found</h2>
                            <p>Please check your database connection and organization data.</p>
                        </article>
                        <% } %>
    </section>

    <%- include("partials/footer") %>
