<%- include("partials/header") %>

    <section class="page-intro">
        <h1>
            <%= title %>
        </h1>
        <p>Browse service project categories and manage category information.</p>
        <p>
            <a href="/new-category">Add New Category</a>
        </p>
    </section>

    <% if (success_messages && success_messages.length> 0) { %>
        <section class="flash-message success">
            <% success_messages.forEach(message=> { %>
                <p>
                    <%= message %>
                </p>
                <% }) %>
        </section>
        <% } %>

            <% if (error_messages && error_messages.length> 0) { %>
                <section class="flash-message error">
                    <% error_messages.forEach(message=> { %>
                        <p>
                            <%= message %>
                        </p>
                        <% }) %>
                </section>
                <% } %>

                    <section class="list-section">
                        <% if (categories && categories.length> 0) { %>
                            <% categories.forEach(category=> { %>
                                <article class="list-item">
                                    <h2>
                                        <a href="/category/<%= category.category_id %>">
                                            <%= category.category_name %>
                                        </a>
                                    </h2>
                                    <p>
                                        <a href="/edit-category/<%= category.category_id %>">Edit Category</a>
                                    </p>
                                </article>
                                <% }) %>
                                    <% } else { %>
                                        <article class="list-item">
                                            <h2>No categories found</h2>
                                            <p>Please check your database connection and category data.</p>
                                        </article>
                                        <% } %>
                    </section>

                    <%- include("partials/footer") %>
