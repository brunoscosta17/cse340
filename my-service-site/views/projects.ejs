<%- include("partials/header") %>

    <section class="page-intro">
        <h1>
            <%= title %>
        </h1>
        <p>
            Browse current service projects and discover ways to get involved in your
            community.
        </p>
    </section>

    <section class="list-section">
        <article class="list-item">
            <h2>Neighborhood Park Cleanup</h2>
            <p>
                Help remove litter, improve green spaces, and make local parks safer and
                more welcoming for everyone.
            </p>
        </article>

        <article class="list-item">
            <h2>After-School Tutoring Program</h2>
            <p>
                Volunteer to support students with reading, math, and homework in a
                positive learning environment.
            </p>
        </article>

        <article class="list-item">
            <h2>Community Food Drive</h2>
            <p>
                Assist with collecting, organizing, and distributing food donations to
                families in need.
            </p>
        </article>

        <article class="list-item">
            <h2>Senior Wellness Visit Program</h2>
            <p>
                Spend time with senior citizens through friendly visits, social
                interaction, and wellness support.
            </p>
        </article>
    </section>

    <%- include("partials/footer") %>
